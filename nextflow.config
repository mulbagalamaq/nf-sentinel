/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-sentinel Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

manifest {
    name            = 'nf-sentinel'
    author          = 'Aymen Maqsood'
    homePage        = 'https://github.com/mulbagalamaq/nf-sentinel'
    description     = 'RNA-seq quantification pipeline with FAIR metadata capture'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=24.04.0'
    version         = '0.1.0-dev'
}

// -- Parameters ----------------------------------------------------------

params {
    // Input/output
    input        = null        // samplesheet CSV
    outdir       = 'results'

    // Salmon
    salmon_index = null        // pre-built Salmon index directory
    tx2gene      = null        // transcript-to-gene mapping TSV

    // FASTP
    adapter_fasta     = null   // custom adapter file (null = auto-detect)
    min_read_length   = 35     // discard reads shorter than this after trimming
    qualified_quality = 15     // phred quality threshold for trimming

    // QC gates (metadata_capture thresholds)
    min_mapping_rate  = 40.0   // percent — below this flags a warning
    min_reads_after_trim = 1000 // samples with fewer reads get flagged
}

// -- Load base config (always applied) -----------------------------------

includeConfig 'conf/base.config'

// -- Profiles ------------------------------------------------------------

profiles {
    docker {
        docker.enabled = true
    }

    singularity {
        singularity.enabled = true
        docker.enabled      = false
    }

    test {
        includeConfig 'conf/test.config'
    }

    aws {
        includeConfig 'conf/aws.config'
    }

    tower {
        includeConfig 'conf/tower.config'
    }
}

// -- Timeline, report, trace ---------------------------------------------

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.svg"
}
