/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-sentinel base config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Resource labels and error handling.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    cpus   = 1
    memory = 2.GB
    time   = 1.h

    withLabel: 'process_low' {
        cpus   = 2
        memory = 4.GB
        time   = 2.h
    }

    withLabel: 'process_medium' {
        cpus   = 4
        memory = 8.GB
        time   = 4.h
    }

    withLabel: 'process_high' {
        cpus   = 8
        memory = 32.GB
        time   = 8.h
    }

    withLabel: 'process_single' {
        cpus   = 1
        memory = 4.GB
        time   = 2.h
    }

    // Retry on OOM (137) or spot preemption (143), not on bugs
    errorStrategy = { task.exitStatus in [137, 143] ? 'retry' : 'finish' }
    maxRetries    = 2
}
