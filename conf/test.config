/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Test profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Minimal resources + test data for CI and local validation.
    Usage: nextflow run main.nf -profile test,docker
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    input        = "${projectDir}/assets/samplesheet.csv"
    outdir       = 'results'
    salmon_index = null  // set after index is built or downloaded
    tx2gene      = null  // transcript-to-gene mapping
}

process {
    cpus   = 1
    memory = 2.GB
    time   = 30.min
}
