/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Test profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Minimal resources + test data for CI and local validation.
    Usage: nextflow run main.nf -profile test,docker
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    input        = "${projectDir}/assets/samplesheet.csv"
    outdir       = 'results'
    salmon_index = "https://raw.githubusercontent.com/nf-core/test-datasets/rnaseq3/reference/salmon.tar.gz"
    tx2gene      = "${projectDir}/assets/tx2gene.tsv"
}

process {
    cpus   = 1
    memory = 2.GB
    time   = 30.min
}
